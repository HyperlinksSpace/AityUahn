# Copy to .env and fill in keys for enabled providers in forge.yaml

PYTHON_CONFIG=forge.yaml
PYTHON_WORKSPACE_ROOT=C:/1/1/1/1/1

ANTHROPIC_API_KEY=
CURSOR_API_KEY=
OPENAI_API_KEY=

# --- Local forge only (aityuahn serve) ---

# --- Cloud SaaS (Vercel + Neon) — see docs/DEPLOY_VERCEL.md ---
# Neon Postgres — use the **pooled** connection string (host contains -pooler)
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# AITYUAHN_JWT_SECRET=generate-a-long-random-string-min-32-chars
# CRON_SECRET=another-long-random-string-for-vercel-cron

# TON payments — optional overrides (wallet & price default from saas.yaml)
# AITYUAHN_TON_WALLET_ADDRESS=
AITYUAHN_TONCENTER_API_KEY=

# Skip DB migrate locally (e.g. vercel dev without Neon)
# SKIP_DB_MIGRATE=1
