{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install -r requirements-vercel.txt",
  "buildCommand": "python scripts/migrate_db.py",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron/ton-poll",
      "schedule": "*/5 * * * *"
    }
  ]
}
